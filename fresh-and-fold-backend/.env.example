# Core production configuration. MONGO_URI and a strong JWT_SECRET are required
# when NODE_ENV=production. Render is expected to proxy one trusted hop.
MONGO_URI=
JWT_SECRET=
TRUST_PROXY_HOPS=1
# Comma-separated browser origins. Required in production; native mobile calls
# without an Origin header remain supported.
HTTP_CORS_ORIGINS=https://admin.example.com
# Broad API flood protection. OTP/Admin/AI retain their own tighter limits.
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=

# AI configuration. AI_PROVIDER defaults to openai when omitted. Keep all keys on the backend only.
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_VISION_MODEL=
AI_TEXT_MODEL=
GEMINI_API_KEY=
GEMINI_VISION_MODEL=
GEMINI_TEXT_MODEL=
AI_REQUEST_TIMEOUT_MS=30000
# Fresh & Fold business calendar used to resolve today/tomorrow booking intent.
BOOKING_TIME_ZONE=Asia/Kolkata
# OTP security. MSG91 is required in production; local OTP mode is never
# enabled automatically and is rejected when NODE_ENV=production.
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_LOCAL_DEV_MODE=false
OTP_LOCAL_DEV_CODE=
# Required for live Razorpay checkout and verified payment.captured webhook
# reconciliation. Keep backend-only; configure the identical webhook secret in
# Razorpay Dashboard. MOCK_PAYMENTS is development-only by policy.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Optional overrides. Defaults: development 100 / 10 minutes; production 10 / 10 minutes.
AI_RATE_LIMIT_WINDOW_MS=600000
AI_RATE_LIMIT_MAX=
# Required when NODE_ENV=production. Separate Socket.IO browser allow-list.
# Native mobile sockets do not send a browser Origin header.
SOCKET_CORS_ORIGINS=https://admin.example.com
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_COUNTRY_CODE=91
