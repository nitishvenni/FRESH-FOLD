{
  "expo": {
    "name": "fresh-and-fold-mobile",
    "slug": "fresh-and-fold-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "freshandfoldmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.freshandfold.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.freshandfold.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Fresh & Fold uses your photos to scan garments for your review.",
          "cameraPermission": "Fresh & Fold uses your camera to scan garments for your review."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Fresh & Fold uses your microphone to turn a spoken booking request into text for your review.",
          "speechRecognitionPermission": "Fresh & Fold uses speech recognition to turn your spoken booking request into editable text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Fresh & Fold uses your location to auto-fill your pickup and delivery address."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://fresh-and-fold-backend.onrender.com",
      "router": {},
      "eas": {
        "projectId": "15ba58d3-a99c-467d-94bd-521ab2127804"
      }
    }
  }
}
